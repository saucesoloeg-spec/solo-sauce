# Firebase (FCM legacy server key)
FIREBASE_SERVER_KEY=your_firebase_server_key_here
# (Optional) Override FCM send URL
FIREBASE_SEND_URL=https://fcm.googleapis.com/fcm/send
# Default notification text
FIREBASE_DEFAULT_TITLE="New Schedule"
FIREBASE_DEFAULT_BODY="You have a new scheduled visit."

# Use HTTP v1 API (recommended). Set to true to use service account JSON and OAuth2.
FIREBASE_USE_V1=true
# Path (relative to project) to downloaded service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=storage/app/firebase-service-account.json
# Your Google Cloud / Firebase project id
FIREBASE_PROJECT_ID=your-firebase-project-id
